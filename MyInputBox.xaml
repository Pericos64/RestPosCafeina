<Window x:Class="RestPOS.MyInputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestPOS"
        mc:Ignorable="d"
        xmlns:k="clr-namespace:RestPOS.Keyboard"  Icon="Res/icon.png"
        Title="Contraseña para la Orden" Height="140" Width="300">
    <StackPanel x:Name="btnInputBox" HorizontalAlignment="Left" Height="95" Margin="12,13,0,0" VerticalAlignment="Top" Width="270">
        <TextBlock TextWrapping="Wrap" Text="Contraseña: "/>
        <PasswordBox  Name="txtPassword"   FontSize="20"  Height="35" k:TouchScreenKeyboard.TouchScreenKeyboard="true"  />
        <Button x:Name="btnInputBox1" Content="Aceptar" Margin="48,0,55,0" Height="30" Click="BtnInputBox1_Click">
        </Button>
    </StackPanel>
</Window>
